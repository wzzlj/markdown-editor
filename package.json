{
  "name": "markdown-editor",
  "version": "0.1.0",
  "description": "A Windows desktop Markdown editor built with Electron, React, and Vite.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron ."
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "dompurify": "^3.3.1",
    "electron": "^39.2.7",
    "lucide-react": "^0.555.0",
    "marked": "^17.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  }
}
